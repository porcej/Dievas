# Copy to .env and adjust values for your environment.
# .env is gitignored and must not be committed.

# Host port mapped to the container (default: 8080)
DIEVAS_HOST_PORT=8080

# ASP.NET Core environment (Production or Development)
ASPNETCORE_ENVIRONMENT=Production

# Semicolon-separated list of allowed CORS origins
Origins=http://localhost:8080

# Application metadata
AppName=Dievas
Version=1.0

# National Weather Service API
NWS__Url=https://api.weather.gov/
NWS__ForecastEndpoint=gridpoints/LWX/96,66/forecast
NWS__User-agent="(Dievas, docker)"
NWS__UpdateIntervalMinutes=15

# Telestaff API (replace placeholder URL and credentials for your deployment)
Telestaff__Url=https://example.com
Telestaff__User-agent="(Dievas, docker)"
Telestaff__TimeFormat=yyyy-MM-dd
Telestaff__UpdateIntervalMinutes=15
Telestaff__ExpirationTimeInMinutes=15
Telestaff__Username=
Telestaff__Password=
Telestaff__AllowInvalidCertificates=false

# Optional SQL Server connection string (not required for basic API operation)
ConnectionStrings__CAD_Reporting=
